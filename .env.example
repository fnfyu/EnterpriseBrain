# LLM
LLM_API_URL=https://xingjiabiapi.org
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-sonnet-4-6

# PostgreSQL / PGVector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_brain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/enterprise_brain

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://localhost:6379/0

# LangSmith
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=enterprise-brain
LANGCHAIN_TRACING_V2=true

# LlamaParse
LLAMA_CLOUD_API_KEY=your_llamaparse_key_here

# E2B (code sandbox)
E2B_API_KEY=your_e2b_key_here

# Auth
SECRET_KEY=your_secret_key_here_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
LOG_LEVEL=INFO
